# Файл — пример. Скопируй в .env и заполни своими значениями.
# В production эти значения берутся не отсюда, а из формы Настройки внутри приложения
# и хранятся в SQLite. .env используется только для локальной разработки.

# МойСклад
VITE_MOYSKLAD_TOKEN=

# EPOS Communicator (по умолчанию — локальный)
VITE_EPOS_COMMUNICATOR_URL=http://localhost:8347/uzpos
VITE_EPOS_TOKEN=DXJFX32CN1296678504F2

# Реквизиты компании (печатаются на чеке)
VITE_COMPANY_NAME=
VITE_COMPANY_INN=
VITE_COMPANY_ADDRESS=
VITE_COMPANY_PHONE=

# Опрос МойСклад (секунды)
VITE_MOYSKLAD_POLL_INTERVAL=30
