{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Базовые разрешения для главного окна EPOS Fiscal",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:event:default",
    "core:path:default",
    "core:app:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    "updater:default",
    "process:default",
    "process:allow-restart",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://api.moysklad.ru/*" },
        { "url": "http://localhost:8347/*" },
        { "url": "http://127.0.0.1:8347/*" },
        { "url": "http://*:8347/*" }
      ]
    }
  ]
}
